# === Ruimtemeesters Browser Chatbot ===
# Copy this to .env and fill in your values:
#   cp .env.rm.example .env

# --- Compose ---
# Tells docker compose which file to use by default
COMPOSE_FILE=docker-compose.rm.yaml

# Port (default 3333)
OPEN_WEBUI_PORT=3333

# Secret key for JWT signing (generate with: openssl rand -hex 32)
WEBUI_SECRET_KEY=

# App branding
WEBUI_NAME=Ruimtemeesters AI

# --- Database ---
POSTGRES_USER=rmchatbot
POSTGRES_PASSWORD=rmchatbot
POSTGRES_DB=rmchatbot

# --- LLM Providers ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Google AI Studio (Gemini). Wired as the 2nd entry in OPENAI_API_BASE_URLS/
# OPENAI_API_KEYS in docker-compose.rm.yaml (OpenAI-compatible endpoint at
# https://generativelanguage.googleapis.com/v1beta/openai/). Free tier has
# per-minute + daily rate limits; paid tier kicks in only after enabling
# billing on the Cloud project AND exceeding free quotas.
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# OpenRouter — gateway to Claude Opus 4.7 (incl. extended-thinking variants),
# DeepSeek, Llama, Qwen, Mistral and many more via a single OpenAI-compatible
# endpoint. Wired as the 3rd entry in OPENAI_API_BASE_URLS/OPENAI_API_KEYS in
# docker-compose.rm.yaml. Share the same key with Ruimtemeesters-Databank.
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Override default model (leave blank to use gemini.gemini-2.5-flash-lite).
# Example for OpenAI: DEFAULT_MODELS=gpt-4o
DEFAULT_MODELS=

# Skip per-model access-control filtering. All chatbot users are Clerk-verified
# (trusted internal); without this, non-admin users see zero models in the
# dropdown because env-based connections (Gemini/OpenRouter/OpenAI) have no
# `model` DB row and the filter only shows unconfigured models to admins.
# Flip to false once a per-model access_grants story is in place.
BYPASS_MODEL_ACCESS_CONTROL=true

# Set to true to re-enable the community share button (disabled by default for internal use).
ENABLE_COMMUNITY_SHARING=

# --- Clerk OIDC ---
# 1. In Clerk Dashboard → OAuth applications → Add OAuth application
# 2. Set redirect URIs:
#    - http://localhost:3333/oauth/oidc/callback (dev)
#    - https://chatbot.datameesters.nl/oauth/oidc/callback (prod)
#    - https://rob.datameesters.nl/oauth/oidc/callback (prod)
# 3. Copy credentials below
CLERK_OIDC_DISCOVERY_URL=
CLERK_OAUTH_CLIENT_ID=
CLERK_OAUTH_CLIENT_SECRET=

# OAuth config
ENABLE_OAUTH_SIGNUP=true
OAUTH_PROVIDER_NAME=Clerk
OAUTH_SCOPES=openid profile email
OAUTH_USERNAME_CLAIM=email
OAUTH_EMAIL_CLAIM=email

# OpenWebUI defaults new signups to role=pending (admin-approval gate). Since Clerk
# already authenticates the user before they reach us, we trust that and land them
# active. Leave at "user" unless you specifically want the approval gate.
DEFAULT_USER_ROLE=user

# --- Clerk SSO (shared cookie from datameesters.nl) ---
# The Clerk secret key is needed to fetch user details from Clerk Backend API.
# Get it from Clerk Dashboard → API keys
CLERK_SECRET_KEY=
CLERK_JWKS_URI=https://clerk.datameesters.nl/.well-known/jwks.json
CLERK_ISSUER=https://clerk.datameesters.nl

# --- MCP API Keys ---
# These are sent as X-API-Key headers to MCP servers, which forward them to backend apps.
# Each backend validates against its own SERVICE_API_KEY env var.
DATABANK_AUTH_TOKEN=
GEOPORTAAL_API_KEY=
TSA_API_KEY=
DASHBOARDING_API_KEY=
RIENS_API_KEY=
SALES_PREDICTOR_API_KEY=
OPDRACHTEN_API_KEY=
AGGREGATOR_API_KEY=
# Memory MCP — gateway-named token: matches MEMORY_API_KEYS=gateway=<this> in
# the MCP-Servers repo. Memory enforces per-user identity via X-Forwarded-User
# (chatbot sets it through ENABLE_FORWARD_USER_INFO_HEADERS).
MEMORY_GATEWAY_TOKEN=
# Memory MCP admin token. Required by the chatbot backend for the admin-only
# /api/v1/admin/memory/stats endpoint. Matches MEMORY_ADMIN_TOKEN on the MCP
# side. Server-side only — never exposed to the browser. Leave blank to keep
# the admin endpoint offline (the chatbot returns 503 with a clear detail).
MEMORY_ADMIN_TOKEN=
# URL of the memory MCP. Default works inside the docker compose network.
# Override when running the chatbot backend outside compose (dev with a
# port-forwarded MCP, etc.).
RM_MEMORY_MCP_URL=http://rm-mcp-memory:3200/mcp

# --- Ollama ---
OLLAMA_DOCKER_TAG=latest

# --- Telemetry ---
SCARF_NO_ANALYTICS=true
DO_NOT_TRACK=true
ANONYMIZED_TELEMETRY=false
